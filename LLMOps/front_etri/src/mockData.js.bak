// datasets/preview API interceptor
  const SAMPLE_IMAGE_BASE64 = "";

  if (cleanUrl === 'datasets/preview') {
    const getParam = (name) => {
      const match = url.match(new RegExp('[?&]' + name + '=([^&]*)'));
      return match ? decodeURIComponent(match[1]) : null;
    };
    
    const datasetId = getParam('dataset_id') || (params && params.dataset_id);
    if (datasetId === 'sds-dataset-v1' || url.includes('sds-dataset-v1')) {
      const fileName = getParam('file_name') || (params && params.file_name) || '';
      const jsonData = SDS_PREVIEW_JSONS[fileName];
      if (jsonData) {
        return {
          status: 1,
          result: {
            type: 'json',
            data: jsonData
          },
          message: 'Success'
        };
      }
      return {
        status: 1,
        result: { type: 'text', data: '(Preview not available for this file type)' },
        message: 'Success'
      };
    } else if (datasetId === 'sds-dataset' || url.includes('sds-dataset')) {
      const fileName = getParam('file_name') || (params && params.file_name) || '';

      if (fileName.endsWith('.md')) {
        return {
          status: 1,
          result: {
            type: 'markdown',
            data: `# Software-defined Ship (SDS) 학습 데이터 - 3차 데이터

에이브노틱스가 제공하는 3차 데이터셋의 주요 목적은 동일한 데이터에 대한 항해상황묘사 및 항해조언 텍스트를 제공하는 것입니다.

본 데이터 생성 시 시뮬레이션은 항해 규칙 교과서의 예시를 기준으로 충돌상황 판단에 대한 사례 상황을 기반으로 만들어졌습니다.

데이터 폴더 이름의 timestamp는 실세계 시간 기반이고, input_data 내 timestamp는 가상세계 시간 기반입니다.

## 개별 데이터 구조

이번 데이터는 학습결과 평가 및 판단에 용이하도록 한국어/영어를 지원하도록 만들었습니다. 더불어 항해조언의 경우 compact 형태도 추가 작성 되었습니다.

### 데이터 폴더 이름 규칙
~~~
{proj}-{source}-{label}-{yyyymmdd}-v{major.minor}-{shortid}
~~~

1. **proj / task**: 프로젝트/태스크 (예: tango_sds)
2. **source / domain**: 데이터 출처/도메인 (예: unity)
3. **label**: 레이블 여부 (안된 경우 none, GPT로 레이블된 경우 llm, 사람이 한 경우 expert)
4. **date**: 생성 날짜 (최소 yyyymmdd)
5. **version**: 의미 있는 변경 시 증가 - 예:0.3
6. **shortid**: 충돌 방지용 8자 해시

### 데이터 폴더 구조

- input_image.png: Unity3D 시뮬레이터에서 특정 상황에 대해 캡쳐된 이미지 화면. 해상도는 1920 × 1080.
- input_data.csv: 캡쳐된 이미지 화면 내 선박에 대한 데이터(자선, 타선 포함). 모든 이미지에 대한 데이터를 담고 있음.
- output_describe_en.txt: 영문 항해상황묘사
- output_describe_kor.txt: 국문 항해상황묘사
- output_advice_en.txt: 영문 항해조언
- output_advice_kor.txt: 국문 항해조언
- output_advice_compact.txt: 간소화한 국문 항해조언

### input_data.csv 데이터 형식

- file_name: 선박 데이터가 담긴 이미지 파일 이름
- timestamp: 이미지가 촬영·수집된 시간
- ship_id: 선박 고유 식별 ID (현재는 int, 추후 변경 가능)
- my_ship: 자선 여부 (1이면 자선, 0이면 아님)
- ship_type: 선박 종류 
- length: 선박 길이
- width: 선박 폭
- draft: 선박의 흘수(수면 아래 잠긴 깊이)
- latitude: 선박 위치의 위도 좌표
- longitude: 선박 위치의 경도 좌표
- knot: 선박 속력(노트 단위)
- heading: 선박 진행 방향(방위각)
- bbox_x: 이미지 내 바운딩 박스 좌상단 X좌표
- bbox_y: 이미지 내 바운딩 박스 좌상단 Y좌표
- bbox_width: 바운딩 박스의 가로 길이
- bbox_height: 바운딩 박스의 세로 길이`
          },
          message: 'Success'
        };
      } else if (fileName.match(/\.(png|jpg|jpeg|gif|bmp|webp)$/i)) {
        return {
          status: 1,
          result: {
            type: 'image',
            data: SAMPLE_IMAGE_BASE64
          },
          message: 'Success'
        };
      } else if (fileName.endsWith('.csv')) {
        return {
          status: 1,
          result: {
            type: 'text',
            data: 'timestamp,my_ship,ship_id,length,width,draft,latitude,longitude,knot,heading,bbox_x,bbox_y,bbox_width,bbox_height\n2026-02-23 05:46:40,1,0,93,28,3,34.454585,127.731907,17.47,140.62,0.0000,0.0000,0.0000,0.0000\n2026-02-23 05:46:40,0,1,134,24,4,34.446715,127.735849,20.08,114.63,974.7662,318.2428,407.9266,263.4319\n'
          },
          message: 'Success'
        };
      } else if (fileName.endsWith('.txt')) {
        let txtData = '';
        if (fileName.includes('output_advice_compact')) {
          txtData = '속도: 현재 17.5노트에서 안전속력으로 즉시 감속\n방향: 우현 30도 이상 변침하여 침로 약 171도로 변경, 타선의 선미를 통과\n근거: 교차 상황(Crossing), 타선이 우현 전방, COLREG 제15조(횡단 항법) 적용, 피항선으로서 우현 변침 의무. 짙은 안개로 시계 극히 제한, 제19조(제한시계) 적용, 제6조 안전속력 감속 필수, 제35조 무중신호 시행 필요.';
        } else if (fileName.includes('output_advice_en')) {
          txtData = 'With a crossing target detected on radar on the starboard bow in dawn fog, immediately reduce to safe speed (Rule 6) and sound fog signals per Rule 35 in accordance with Rule 19. Continuously calculate the target\'s CPA and TCPA through radar plotting, and if risk of collision is confirmed, avoid altering course to port and secure a safe passing distance by altering course to starboard or reducing speed.';
        } else if (fileName.includes('output_advice_kor')) {
          txtData = '시계가 극히 제한된 상황에서 우현 전방의 교차 타선이 레이더에 탐지되었으므로, 제19조에 따라 즉시 안전한 속력(제6조)으로 감속하고 제35조의 무중신호를 취명하십시오. 제19조(d)(i)항에 따라 좌현 변침은 반드시 피하고, 우현 변침 또는 감속으로 CPA 1마일 이상의 안전 거리를 확보하십시오. 레이더 플로팅으로 CPA를 지속 감시하십시오.';
        } else if (fileName.includes('output_describe_en')) {
          txtData = 'Dawn fog covers the sea surface at low level restricting visibility. Own vessel is proceeding southeast on course 141 degrees at approximately 17.5 knots, while a target vessel on course 115 degrees at approximately 20.1 knots has been detected on radar on the starboard bow proceeding east-southeast in a developing crossing situation.';
        } else if (fileName.includes('output_describe_kor')) {
          txtData = '짙은 안개로 시계가 극히 제한된 제한시계 상황이다. 본선은 침로 140.6도, 약 17.5노트로 남동 방향 항해 중이며, 우현 전방에서 침로 114.6도, 약 20.1노트의 타선이 동남동 방향으로 본선의 진로를 가로지르는 교차 상황(Crossing)이 레이더에 탐지되었다. 타선의 속력이 빠르고 무시계이므로 위험도가 높다.';
        } else {
          txtData = `Sample mock preview content for SDS text file: ${fileName}`;
        }
        return {
          status: 1,
          result: {
            type: 'text',
            data: txtData
          },
          message: 'Success'
        };
      }

      return {
        status: 1,
        result: { type: 'text', data: '(Preview not available for this file type)' },
        message: 'Success'
      };
    }
  }

  if (cleanUrl === 'models') {
    if (method && method.toLowerCase() === 'put') {
      if (body && body.model_id) {
        const model = mockResponses['models']?.result?.find(m => m.id === body.model_id);
        if (model) {
          if (body.model_name !== undefined) {
            model.name = body.model_name;
          }
          if (body.description !== undefined) {
            model.description = body.description;
          }
          if (body.access !== undefined) {
            model.is_access = body.access === 1;
          }
          if (body.user_list !== undefined) {
            model.users = body.user_list.map(id => {
              return {
                user_id: id,
                user_name: id === 'u-1' ? 'admin' : (id === 'dummy-session-etri' || id === 'etri' ? 'etri' : 'demo')
              };
            });
          }
          model.update_datetime = new Date().toISOString();
          return {
            status: 1,
            result: model,
            message: 'Success',
          };
        }
      }
      return {
        status: 0,
        message: 'Model not found',
        error: { code: 'NOT_FOUND' },
      };
    }
  }

  // Try clean url match
  if (mockResponses[cleanUrl]) {
    return mockResponses[cleanUrl];
  }
  
  if (cleanUrl.startsWith('storage/') && cleanUrl.endsWith('/workspace')) {
    return {
      status: 1,
      result: {
        share: 0,
        workspace: {
          workspace_size: 5000000000000,
          workspace_used: 1000000000000,
          workspace_avail: 4000000000000,
          workspace_pcent: 20
        }
      },
      message: 'Success'
    };
  }

  // Check parameterized matches (e.g. models/commit-models/1, external/manifests/name)
  if (cleanUrl.startsWith('models/commit-models/')) {
    return {
      status: 1,
      result: {
        commits: [
          { id: 'c1', message: 'Initial model weights', date: '2026-06-09' }
        ]
      },
      message: 'Success'
    };
  }
  
  if (cleanUrl.startsWith('external/manifests/')) {
    return {
      status: 1,
      result: {
        name: decodeURIComponent(cleanUrl.split('/').pop()),
        versions: [
          {
            manifest_version: 'v1.0.0',
            default_params: {
              batch_size: 8,
              learning_rate: 0.0001,
              epochs: 5,
              optimizer: 'adamw',
            }
          }
        ]
      },
      message: 'Success'
    };
  }

  if (cleanUrl === 'models/fine-tuning/summary') {
    const modelIdMatch = url.match(/[?&]model_id=([^&#]*)/);
    const modelId = modelIdMatch ? modelIdMatch[1] : (params?.model_id || '');
    const model = mockResponses['models']?.result?.find(m => m.id === modelId);

    if (model) {
      return {
        status: 1,
        result: {
          ...model,
          huggingface_model_id: model.huggingface_model_id || 'meta-llama/Meta-Llama-3-8B',
          commit_model_name: model.commit_model_name || '',
          load_type: model.load_type || 'single'
        },
        message: 'Success'
      };
    }

    const isExternal = modelId === 'sdm';
    return {
      status: 1,
      result: {
        name: modelId === 'sds' ? 'SDS' : (isExternal ? 'SDM' : 'SDF'),
        description: modelId === 'sds' ? 'Llama 3 8B Instruction tuned model' : 'Model description',
        create_user_name: 'admin',
        create_datetime: '2026-06-09T01:00:00Z',
        update_datetime: '2026-06-09T01:00:00Z',
        huggingface_model_id: modelId === 'sds'
          ? 'openai/clip-vit-large-patch14-336,meta-llama/Llama-3.1-8B-Instruct'
          : 'meta-llama/Meta-Llama-3-8B',
        load_type: modelId === 'sds' ? 'multimodal' : 'single',
        commit_model_name: '',
      },
      message: 'Success'
    };
  }

  if (cleanUrl === 'models/fine-tuning') {
    const modelIdMatch = url.match(/[?&]model_id=([^&#]*)/);
    const modelId = modelIdMatch ? modelIdMatch[1] : (params?.model_id || '');
    const isExternal = modelId === 'sdm';

    return {
      status: 1,
      result: {
        model_name: isExternal ? 'SDM' : 'SDS',
        commit_model_name: isExternal ? 'SDM/v1.0' : 'SDS/v1.0',
        training_type: isExternal ? 'external' : 'internal',
        huggingface_git: 'https://huggingface.co/meta-llama/Meta-Llama-3-8B',
        huggingface_mode_id: modelId === 'sds'
          ? 'openai/clip-vit-large-patch14-336,meta-llama/Llama-3.1-8B-Instruct'
          : 'meta-llama/Meta-Llama-3-8B',
        model_datasets: [
          { id: 1, name: 'SDS Dataset' }
        ],
        model_config_file_list: [
          { file_name: 'config.json' }
        ],
        resource_info: 'GPU: NVIDIA A100 80GB x 1',
        latest_commit_info: {
          name: 'v1.0'
        },
        fine_tuning_config: isExternal ? null : {
          num_train_epochs: 3,
          gradient_accumulation_steps: 1,
          cutoff_length: 512,
          learning_rate: 0.00005,
          warmup_steps: 100,
          used_jonathan_accelerator: 1,
          load_in_8bit: 0,
          used_lora: 1,
          fine_tuning_type: 'basic'
        },
        stage1_config: modelId === 'sds' ? {
          num_train_epochs: 3,
          learning_rate: 0.00003,
          per_device_train_batch_size: 8,
          warmup_steps: 150,
        } : null,
        stage2_config: modelId === 'sds' ? {
          num_train_epochs: 5,
          learning_rate: 0.00005,
          per_device_train_batch_size: 4,
          warmup_steps: 100,
          cutoff_length: 1024,
          gradient_accumulation_steps: 2,
          load_in_8bit: 0,
          used_lora: 1,
        } : null
      },
      message: 'Success'
    };
  }

  // Playgrounds API dynamic endpoints
  if (cleanUrl.startsWith('playgrounds/')) {
    const parts = cleanUrl.split('/');
    // playgrounds/status/:id
    if (parts[1] === 'status') {
      return {
        status: 1,
        result: {
          status: 'Running',
        },
        message: 'Success',
      };
    }
    // playgrounds/model
    if (parts[1] === 'model') {
      return {
        status: 1,
        result: [
          {
            model_type: 'HF',
            model_hf_id: 'meta-llama/Meta-Llama-3-8B-Instruct',
            model_allm_id: 'sds',
            model_allm_name: 'SDS',
            description: 'SDS Llama 3 8B model',
          }
        ],
        message: 'Success',
      };
    }
    // playgrounds/rag
    if (parts[1] === 'rag') {
      return {
        status: 1,
        result: [
          {
            id: 'rag-1',
            name: 'SDS RAG Dataset',
          }
        ],
        message: 'Success',
      };
    }
    // playgrounds/prompt
    if (parts[1] === 'prompt') {
      if (parts[2] === 'commit') {
        return {
          status: 1,
          result: [
            {
              id: 'commit-1',
              commit_name: 'v1.0.0',
              system_message: 'You are a helpful assistant.',
              user_message: 'Hello!',
            }
          ],
          message: 'Success',
        };
      }
      return {
        status: 1,
        result: [
          {
            id: 'prompt-1',
            name: 'SDS General Prompt',
          }
        ],
        message: 'Success',
      };
    }
    // playgrounds/instance
    if (parts[1] === 'instance') {
      return {
        status: 1,
        result: {
          list: [
            {
              id: 'inst-1',
              name: 'GPU Instance 1',
              status: 'Running',
            }
          ]
        },
        message: 'Success',
      };
    }
    // playgrounds/users
    if (parts[1] === 'users') {
      return {
        status: 1,
        result: [
          { user_id: 'u-1', user_name: 'admin' },
          { user_id: 'dummy-session-etri', user_name: 'etri' }
        ],
        message: 'Success',
      };
    }
    // playgrounds/monitoring
    if (parts[1] === 'monitoring') {
      return {
        status: 1,
        result: {
          monitoring_id: 'monitor-1',
        },
        message: 'Success',
      };
    }
    // playgrounds/test/options
    if (parts[1] === 'test' && parts[2] === 'options') {
      return {
        status: 1,
        result: {
          options: [],
        },
        message: 'Success',
      };
    }
    // playgrounds/test/dataset
    if (parts[1] === 'test' && parts[2] === 'dataset') {
      return {
        status: 1,
        result: {
          list: [],
        },
        message: 'Success',
      };
    }
    // playgrounds/test/log
    if (parts[1] === 'test' && parts[2] === 'log') {
      return {
        status: 1,
        result: {
          logs: [],
        },
        message: 'Success',
      };
    }

    // playgrounds/:playgroundId (GET)
    // playgrounds/:playgroundId (DELETE) 등
    if (parts.length === 2 && parts[1] !== 'start' && parts[1] !== 'stop' && parts[1] !== 'options' && parts[1] !== 'description') {
      if (method && method.toLowerCase() === 'delete') {
        return {
          status: 1,
          result: {},
          message: 'Success',
        };
      }
      return {
        status: 1,
        result: {
          info: {
            id: parts[1],
            create_datetime: '2026-06-09T05:00:00Z',
            description: 'Mock Playground Description',
            name: 'Mock Playground',
            owner: 'admin',
            update_datetime: '2026-06-09T05:00:00Z',
            access: 1,
            users: [],
          },
          info_instance: {
            model: {
              instance_id: 1,
              instance_type: 'GPU',
              instance_name: 'GPU Node A100',
              instance_allocate: 1,
              gpu_allocate: 1,
              gpu_available: true,
              cpu_allocate: 4,
              cpu_available: true,
              ram_allocate: 16,
              ram_available: true,
              instance_available: true,
            },
            embedding: {
              instance_id: 1,
              instance_type: 'GPU',
              instance_name: 'GPU Node A100',
              instance_allocate: 1,
              gpu_allocate: 1,
              gpu_available: true,
              cpu_allocate: 4,
              cpu_available: true,
              ram_allocate: 16,
              ram_available: true,
              instance_available: true,
            },
            reranker: {
              instance_id: 1,
              instance_type: 'GPU',
              instance_name: 'GPU Node A100',
              instance_allocate: 1,
              gpu_allocate: 1,
              gpu_available: true,
              cpu_allocate: 4,
              cpu_available: true,
              ram_allocate: 16,
              ram_available: true,
              instance_available: true,
            },
            immediately_status: 'running',
          },
          info_request: {
            method: 'POST',
            url: 'http://localhost:8000',
            body: '{}',
          },
          model: {
            model_type: 'HF',
            model_hf_id: 'meta-llama/Meta-Llama-3-8B-Instruct',
            model_allm_id: 'sds',
            model_allm_name: 'SDS',
            model_allm_commit_id: 'c1',
            model_allm_commit_name: 'Initial model weights',
            training_type: 'lora',
            description: 'Mock Model Description',
            commit: 'c1',
            access: 1,
            create_datetime: '2026-06-09T05:00:00Z',
            update_datetime: '2026-06-09T05:00:00Z',
          },
          model_parameter: {
            temperature: 0.7,
            top_p: 0.9,
            top_k: 50,
            repetition_penalty: 1.1,
            max_new_tokens: 512,
          },
          rag: {
            id: 'rag-1',
            name: 'Mock RAG',
            chunk_len: 500,
            chunk_max: 1000,
            docs_total_count: 5,
            docs_total_size: 102400,
            rag_doc_list: [],
            embedding_huggingface_model_id: 'BAAI/bge-m3',
            reranker_huggingface_model_id: 'BAAI/bge-reranker-large',
          },
          prompt: {
            id: 'prompt-1',
            name: 'Mock Prompt',
            commit_name: 'v1.0',
            system_message: 'You are a helpful assistant.',
            user_message: 'Hello!',
          },
        },
        message: 'Success',
      };
    }
  }

  // Generic list responses for unmapped lists
  if (cleanUrl.endsWith('s') || cleanUrl.includes('list') || cleanUrl.includes('options')) {
    return {
      status: 1,
      result: { list: [] },
      message: 'Success',
    };
  }

  // Default fallback response
  return {
    status: 1,
    result: {},
    message: 'Mock Success fallback',
  };
};

