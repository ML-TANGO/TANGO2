    # ========================================================================
    # RDMA Settings (고성능 GPU 통신, 선택사항)
    # ========================================================================
    # RDMA(Remote Direct Memory Access)는 GPU 간 고속 데이터 전송을 위한 설정입니다.
    # ※ InfiniBand 또는 RoCE 네트워크가 구성된 환경에서만 사용
    # ※ 일반 이더넷 환경에서는 enabled: false로 두세요.
    #
    # 활성화 조건:
    #   - InfiniBand/RoCE NIC가 장착된 GPU 노드
    #   - RDMA 디바이스 플러그인이 Kubernetes에 설치됨
    #   - 노드 간 RDMA 네트워크 연결 확인 완료
    # ========================================================================
    rdma:
      enabled: false                              # RDMA 사용 시 true

      # Multi-Process Service (MPS) 설정
      # ※ 여러 프로세스가 하나의 GPU를 공유할 때 사용
      mp:
        enabled: false                            # MPS 사용 시 true
        seedNum: 3                                # 시드 노드 수 (분산 학습 초기화용)
        nodeSeedList: []                          # 시드 노드 호스트명 목록
                                                  # 예: ["gpu-node-01", "gpu-node-02", "gpu-node-03"]

      # RDMA 성능 최적화 설정
      perf:
        enabled: false                            # 성능 최적화 사용 시 true
        p2p: []                                   # RDMA P2P(Peer-to-Peer)로 연결된 노드 쌍 목록
                                                  # 예: [["gpu-node-01", "gpu-node-02"],
                                                  #      ["gpu-node-03", "gpu-node-04"]]
